{
  "name": "job-scraper",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "tsc",
    "build:frontend": "vite build --config apps/frontend/vite.config.ts",
    "dev:backend": "npm run build && npm run start:backend",
    "dev:frontend": "vite --config apps/frontend/vite.config.ts",
    "start:backend": "node dist/apps/backend/src/server.js",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "^5.9.0",
    "vite": "^8.0.10"
  },
  "dependencies": {
    "@types/web-push": "^3.6.4",
    "cheerio": "^1.2.0",
    "express": "^5.2.1",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "web-push": "^3.6.7"
  }
}
